# ── OpenAI ─────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Telegram ───────────────────────────────────────────────────────────
TELEGRAM_TOKEN=123456789:AAF...

# ── Chiffrement (32 bytes hex = 64 chars) ──────────────────────────────
ENCRYPTION_KEY=00112233445566778899aabbccddeeff00112233445566778899aabbccddeeff

# ── Stripe ─────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...
APP_URL=https://yourdomain.com

# ── Base de données (Docker Compose) ───────────────────────────────────
POSTGRES_PASSWORD=lunapass
# Si vous utilisez une DB externe (ex: Supabase) :
# DATABASE_URL=postgresql://user:pass@host:5432/luna?sslmode=require

# ── URLs des services (développement local) ────────────────────────────
# Ces variables sont injectées automatiquement par Docker Compose.
# Pour le développement sans Docker :
CHAT_SERVICE_URL=http://localhost:8001
MEMORY_SERVICE_URL=http://localhost:8002
PERSONALITY_SERVICE_URL=http://localhost:8003
PAYMENT_SERVICE_URL=http://localhost:8004
